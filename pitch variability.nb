   RowBox[{
    RowBox[{"shiftsPerWeek", "=", "12."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hoursPerShift", "=", "8."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"daysPerWeek", "=", "5."}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Demand", ":", 
     RowBox[{"240000", " ", 
