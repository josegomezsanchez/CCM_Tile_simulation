   RowBox[{
    RowBox[{"hoursPerDayDryMill", "=", 
     RowBox[{"hoursPerWeekKiln", "/", "daysPerWeek"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"One", " ", "changeover", " ", "per", " ", "day", " ", 
