    RowBox[{"2", "-", 
     RowBox[{"hour", " ", "CO", " ", "between", " ", "colors"}]}], "*)"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Daily", " ", "available", " ", "hours", " ", "for", " ", "dry", " ", 
