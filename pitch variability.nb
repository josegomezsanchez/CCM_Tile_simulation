     RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "="}], 
    "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"workingDaysPerYear", "=", "240."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tilesPerCase", "=", "24."}], ";"}], "\n", 
