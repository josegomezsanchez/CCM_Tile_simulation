   RowBox[{
    RowBox[{"casesPerYear", "=", "240000."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tilesPerYear", "=", 
     RowBox[{"casesPerYear", "*", "tilesPerCase"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tilesPerDayDemand", "=", 
     RowBox[{"tilesPerYear", "/", "workingDaysPerYear"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Split", " ", "demand", " ", "between", " ", "white", " ", "and", " ", 
